{
    "name": "crypto-calculator-frontend",
    "version": "1.0.0",
    "description": "Crypto Calculator SaaS - Frontend React application with trading calculators, AI advisor, and subscription management",
    "private": true,
    "type": "module",
    "author": "Crypto Calculator Team <contact@crypto-calculator.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-org/crypto-calculator-saas"
    },
    "homepage": "https://crypto-calculator.com",
    "bugs": {
        "url": "https://github.com/your-org/crypto-calculator-saas/issues"
    },
    "keywords": [
        "crypto",
        "trading",
        "calculator",
        "saas",
        "react",
        "tailwindcss",
        "supabase",
        "stripe",
        "finance",
        "investment"
    ],
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint src --ext js,jsx --fix",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,json}\" --config .prettierrc",
        "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md,json}\" --config .prettierrc",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "analyze": "vite-bundle-analyzer",
        "security-check": "npm audit --production",
        "clean": "rm -rf dist node_modules/.vite",
        "preinstall": "npx only-allow npm",
        "prepare": "husky install",
        "deploy:staging": "npm run build && echo 'Deploy to staging'",
        "deploy:production": "npm run build && echo 'Deploy to production'"
    },
    "dependencies": {
        "@gsap/react": "^2.1.2",
        "@stripe/react-stripe-js": "^2.3.2",
        "@stripe/stripe-js": "^2.1.7",
        "@supabase/supabase-js": "^2.39.7",
        "axios": "^1.13.5",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "decimal.js": "^10.4.3",
        "dotenv": "^17.3.1",
        "framer-motion": "^10.16.5",
        "gsap": "^3.14.2",
        "html2canvas": "^1.4.1",
        "js-cookie": "^3.0.5",
        "lightweight-charts": "^5.1.0",
        "lucide-react": "^0.309.0",
        "ogl": "^1.0.11",
        "react": "^18.2.0",
        "react-countup": "^6.4.0",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.2.0",
        "react-error-boundary": "^4.0.11",
        "react-hot-toast": "^2.4.1",
        "react-intersection-observer": "^9.5.3",
        "react-router-dom": "^6.20.0",
        "recharts": "^3.7.0",
        "swr": "^2.4.0",
        "tailwind-merge": "^3.5.0",
        "three": "^0.183.1"
    },
    "devDependencies": {
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@testing-library/jest-dom": "^6.1.6",
        "@testing-library/react": "^14.1.2",
        "@testing-library/user-event": "^14.5.2",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^20.10.5",
        "@types/react": "^18.2.45",
        "@types/react-dom": "^18.2.18",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "@vitejs/plugin-legacy": "^5.0.4",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "cross-env": "^7.0.3",
        "eslint": "^8.57.1",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "husky": "^8.0.3",
        "jsdom": "^23.0.1",
        "lint-staged": "^15.2.0",
        "postcss": "^8.4.32",
        "prettier": "^3.1.1",
        "prettier-plugin-tailwindcss": "^0.5.11",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.3.3",
        "vite": "^5.0.8",
        "vite-plugin-checker": "^0.6.3",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-pwa": "^0.17.4",
        "vitest": "^1.0.4"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all",
            "not ie > 0",
            "not samsung 4",
            "not baidu 7"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "volta": {
        "node": "20.10.0",
        "npm": "10.2.3"
    }
}
